# ─── OpenClaw Voice Assistant — Variáveis de Ambiente ─────────────────────────
# Copie para .env e ajuste conforme necessário. Todos os valores são opcionais.

# URL do endpoint do gateway OpenClaw
# Default: http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1/chat/completions

# Token de autenticação do gateway (override)
# Default: carregado de ~/.openclaw/openclaw.json
# OPENCLAW_GATEWAY_TOKEN=

# Modelo/agente a ser usado nas conversas
# Default: openclaw:main
OPENCLAW_MODEL=openclaw:main

# Voz do Edge TTS (usada como fallback ou quando TTS_ENGINE=edge)
# Opções PT-BR: pt-BR-AntonioNeural, pt-BR-FranciscaNeural, pt-BR-ThalitaNeural
# Default: pt-BR-AntonioNeural
TTS_VOICE=pt-BR-AntonioNeural

# Engine de TTS: "kokoro" (melhor qualidade, local), "piper" (leve, local) ou "edge" (online)
# Fallback automático: kokoro → piper → edge
# Default: piper
TTS_ENGINE=piper

# Modelo Whisper para STT: tiny, base, small, medium, large-v3
# tiny (~75MB, rápido) | small (~460MB, bom) | medium (~1.5GB, ótimo)
# Default: small
WHISPER_MODEL=small

# Host do servidor Gradio
# Default: 0.0.0.0
SERVER_HOST=0.0.0.0

# Porta do servidor Gradio
# Default: 7860
PORT=7860
